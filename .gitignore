# Dart/Flutter
.dart_tool/
.packages
.pub-cache/
.pub/
build/
doc/api/
pubspec.lock            # library package: do not commit the lockfile

# fvm (keep .fvmrc, ignore the local SDK cache/symlink)
.fvm/

# IDEs
.idea/
*.iml
.vscode/

# Coverage
coverage/

# Misc
*.log
*.swp
staging/

# OS
.DS_Store
Thumbs.db

# Golden references: only the committed CI flavor enters history.
test/**/goldens/*/
!test/**/goldens/ci/
# Mismatch artifacts alchemist writes beside a failing test.
test/**/failures/
